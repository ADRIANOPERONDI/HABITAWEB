# CONFIGURAÇÃO PARA TESTES
# Data: 2026-03-25
# SECURITY NOTE: This file contains test credentials only. Real API keys are loaded from environment.

CI_ENVIRONMENT = testing

# Database (usar BD de teste isolada)
database.default.hostname = localhost
database.default.database = habitaweb_test
database.default.username = postgres
database.default.password = postgres
database.default.DBDriver = Postgre
database.default.port = 5432
database.default.charset = utf8
database.default.DBDebug = true

# App
app.baseURL = 'http://localhost:8080/'

# Encryption - SECURITY: Replace with unique random value per test environment
encryption.key = hex:40f71c4fe7f7381b05fa0f6ce1c7ebc2fb89c367f18932b5b8976de51785b78f

# Cache (Redis) - índices 6/7, isolados do dev (4/5) e de outros projetos que
# usam este mesmo Redis local (DB 0-2 já ocupados por outro app da máquina)
cache.handler = redis
cache.backupHandler = file
cache.redis.host = 127.0.0.1
cache.redis.port = 6379
cache.redis.timeout = 1
cache.redis.database = 6

# Session (Redis)
session.driver = CodeIgniter\Session\Handlers\RedisHandler
session.savePath = tcp://127.0.0.1:6379?database=7&timeout=1

# Email
email.protocol = mail
email.fromEmail = teste@habitaweb.com.br
email.fromName = HabitaWeb Teste

# Asaas (Sandbox) - SECURITY: Real keys must come from environment variables, not .env files
ASAAS_ENV=sandbox
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_WEBHOOK_SECRET=
ASAAS_SUBSCRIPTION_BILLING_TYPE=UNDEFINED
ASAAS_SINGLE_CHARGE_BILLING_TYPES=PIX,BOLETO,CREDIT_CARD

# Stripe (Test Mode) - SECURITY: Real keys must come from environment variables
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# Mercado Pago (Test Mode) - SECURITY: Real keys must come from environment variables
MP_ACCESS_TOKEN=

# Payment Gateway Testing
PAYMENT_GATEWAY_TESTING=true
