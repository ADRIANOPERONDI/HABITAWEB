# Ambiente
CI_ENVIRONMENT = development
app.baseURL = 'http://localhost:8080/'

# Banco de dados
database.default.hostname = 127.0.0.1
database.default.database = habitaweb
database.default.username = habitaweb
database.default.password = CHANGE_ME
database.default.DBDriver = Postgre
database.default.port = 5432
database.default.charset = utf8
database.default.DBDebug = true

# Gere uma chave exclusiva com: php spark key:generate
encryption.key =

# Cache e sessão
cache.handler = file
cache.backupHandler = file
cache.redis.host = 127.0.0.1
cache.redis.port = 6379
cache.redis.timeout = 1
cache.redis.database = 0
session.driver = CodeIgniter\Session\Handlers\FileHandler
session.savePath =

# E-mail
email.protocol = smtp
email.fromEmail = no-reply@example.com
email.fromName = Habitaweb

# Pagamentos: configure somente no ambiente de execução
ASAAS_ENV = sandbox
ASAAS_API_KEY =
ASAAS_WEBHOOK_TOKEN =
ASAAS_WEBHOOK_SECRET =
ASAAS_SUBSCRIPTION_BILLING_TYPE = UNDEFINED
ASAAS_SINGLE_CHARGE_BILLING_TYPES = PIX,BOLETO,CREDIT_CARD

# Storage
storage.driver = local
storage.s3.key =
storage.s3.secret =
storage.s3.region =
storage.s3.bucketPublic =
storage.s3.bucketPrivate =
storage.s3.endpoint =
storage.s3.publicBaseUrl =
